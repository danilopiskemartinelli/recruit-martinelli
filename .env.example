# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=hr_user
POSTGRES_PASSWORD=hr_secret_change_me
POSTGRES_DB=hr_platform
DATABASE_URL=postgresql+asyncpg://hr_user:hr_secret_change_me@localhost:5432/hr_platform
SYNC_DATABASE_URL=postgresql://hr_user:hr_secret_change_me@localhost:5432/hr_platform

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT / Security ─────────────────────────────────────────
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── AI Provider ────────────────────────────────────────────
# Options: opencode | openai | anthropic
AI_PROVIDER=opencode
OPENCODE_API_KEY=
OPENCODE_API_BASE_URL=https://api.opencode.ai/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Email / SMTP ───────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hrplatform.com
SMTP_USE_TLS=false

# ── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=HR Platform

# ── File Storage ───────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads

# ── Digital Signature ──────────────────────────────────────
SIGNATURE_CERT_PATH=./certs/signing.crt
SIGNATURE_KEY_PATH=./certs/signing.key

# ── Application ────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
LOG_LEVEL=INFO
